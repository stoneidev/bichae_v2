{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bichae-v2",
  "pages_build_output_dir": ".vercel/output/static",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["async_local_storage", "nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bichae-db",
      "database_id": "local-bichae-db-id"
    }
  ]
}
